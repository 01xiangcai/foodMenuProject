.detail-page {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero-photo {
  width: 100%;
  height: 360rpx;
  border-radius: 32rpx;
}

.head-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
}

.badge {
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.meta {
  display: flex;
  gap: 8rpx;
  opacity: 0.8;
}

.flavor {
  font-size: 26rpx;
  opacity: 0.85;
}

.description {
  line-height: 1.7;
}

.tips {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.03);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.tips-title {
  font-weight: 600;
}

.comment-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.comment-card {
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.03);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.comment-head {
  display: flex;
  justify-content: space-between;
}

.author {
  font-weight: 600;
}

.time {
  font-size: 24rpx;
  opacity: 0.6;
}

.comment-content {
  line-height: 1.6;
}

.toggle {
  display: inline-flex;
  gap: 6rpx;
  font-size: 24rpx;
  color: #38bdf8;
  align-items: center;
}

.replies {
  margin-top: 8rpx;
  padding-left: 16rpx;
  border-left: 2rpx dashed rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.reply {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.empty-tip {
  text-align: center;
  padding: 30rpx 0;
  opacity: 0.6;
}

.empty-page {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.6);
}

