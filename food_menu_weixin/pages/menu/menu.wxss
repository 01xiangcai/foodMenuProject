.menu-page {
  display: flex;
  height: 100vh;
  background: var(--bg-color);
  box-sizing: border-box;
  overflow: hidden;
  color: var(--text-color);
}

/* Side Navigation */
.side-nav {
  width: 180rpx;
  height: 100%;
  background: rgba(255, 255, 255, 0.05);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  border-right: 1rpx solid var(--border-color);
}

.parent-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 36rpx 10rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  position: relative;
  transition: all 0.3s ease;
}

.parent-card.active {
  background: var(--card-bg);
  color: var(--text-color);
  font-weight: 600;
}

.parent-card.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background: var(--primary-color);
  border-radius: 0 6rpx 6rpx 0;
}

.parent-card .icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
  transition: transform 0.3s;
}

.parent-card.active .icon {
  transform: scale(1.1);
}

/* Dish List */
.dish-list {
  flex: 1;
  height: 100%;
  padding: 20rpx 24rpx;
  overflow-y: auto;
  box-sizing: border-box;
  background: transparent;
}

.dish-card {
  display: flex;
  padding: 24rpx;
  margin-bottom: 24rpx;
  background: var(--card-bg);
  border-radius: 24rpx;
  box-shadow: var(--glass-shadow);
  position: relative;
  animation: fadeIn 0.5s ease-out;
  border: 1rpx solid var(--card-border);
}

.dish-photo-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.dish-photo {
  width: 100%;
  height: 100%;
  background-color: #333;
}

/* Favorite Button on Image */
.btn-favorite {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(4px);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  z-index: 10;
  transition: transform 0.2s;
}

.btn-favorite:active {
  transform: scale(0.9);
}

.favorite-icon {
  font-size: 28rpx;
  line-height: 1;
}

.favorite-icon.active {
  animation: heartBeat 0.4s ease-in-out;
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

/* Dish Info */
.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.dish-header {
  display: flex;
  flex-direction: column;
}

.dish-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.dish-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-right: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  background: var(--tag-bg);
  color: var(--primary-color);
  font-weight: 500;
}

.dish-summary {
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Footer: Price & Actions */
.dish-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 12rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  color: #ff4d4f;
  font-weight: bold;
}

.currency {
  font-size: 24rpx;
  margin-right: 2rpx;
}

.price {
  font-size: 36rpx;
}

.unit {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: normal;
  margin-left: 4rpx;
}

/* Action Buttons */
.action-buttons {
  display: flex;
  align-items: center;
}

.quantity-control {
  display: flex;
  align-items: center;
  margin-right: 16rpx;
  background: var(--input-bg);
  border-radius: 30rpx;
  padding: 2rpx;
  border: 1rpx solid var(--input-border);
}

.btn-minus, .btn-plus {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  padding: 0;
  transition: all 0.2s;
}

.btn-minus {
  color: var(--text-color);
  background: transparent;
}

.btn-plus {
  background: var(--primary-color);
  color: #fff;
  box-shadow: 0 4rpx 10rpx rgba(20, 184, 255, 0.3);
}

.btn-plus:active, .btn-minus:active {
  transform: scale(0.9);
}

.count {
  min-width: 40rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-color);
  margin: 0 4rpx;
}

/* Cart Bar */
.list-bottom-placeholder {
  height: 180rpx;
}

.cart-bar {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  height: 110rpx;
  background: rgba(30, 30, 30, 0.9);
  backdrop-filter: blur(10px);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  z-index: 100;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.25);
  animation: slideUp 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.cart-icon-wrap {
  position: relative;
  width: 90rpx;
  height: 90rpx;
  background: #333;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -30rpx;
  margin-right: 24rpx;
  border: 6rpx solid #1e1e1e;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

.cart-icon {
  font-size: 48rpx;
}

.cart-icon-wrap .badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  border: 2rpx solid #333;
}

.price-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.total-price {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
}

.delivery-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.btn-checkout {
  background: linear-gradient(135deg, #ff7875, #ff4d4f);
  color: #fff;
  padding: 0 56rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 79, 0.4);
  transition: transform 0.2s;
}

.btn-checkout:active {
  transform: scale(0.96);
}

/* Cart Popup */
.cart-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 98;
  backdrop-filter: blur(4px);
  animation: fadeIn 0.3s;
}

.cart-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--modal-bg);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 99;
  padding: 32rpx 32rpx 160rpx 32rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
  animation: slideUp 0.3s ease-out;
  display: flex;
  flex-direction: column;
  max-height: 70vh;
  border-top: 1rpx solid var(--card-border);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  margin-bottom: 0;
  background: transparent;
}

.cart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
}

.cart-clear {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 10rpx;
}

.cart-list {
  flex: 1;
  overflow-y: auto;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.cart-item:last-child {
  border-bottom: none;
}

.cart-item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: #333;
  flex-shrink: 0;
}

.cart-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.cart-item-name {
  font-size: 30rpx;
  color: var(--text-color);
  font-weight: 500;
}

.cart-item-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.cart-item .quantity-control {
  margin-right: 0;
  background: transparent;
  border: none;
}
