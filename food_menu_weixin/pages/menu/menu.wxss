.menu-page {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  height: calc(100vh - 48rpx);
  box-sizing: border-box;
}

.side-nav {
  width: 190rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  height: 100%;
  overflow-y: scroll;
}

.parent-card {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.02);
  border: 1rpx solid transparent;
  opacity: 0.5;
  transition: 0.2s;
}

.parent-card.active {
  opacity: 1;
  border-color: rgba(255, 255, 255, 0.1);
  box-shadow: 0 12rpx 30rpx rgba(20, 184, 255, 0.25);
}

.parent-card .icon {
  font-size: 32rpx;
}

.dish-list {
  flex: 1;
  padding-left: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  height: 100%;
  overflow-y: scroll;
}

.dish-card {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.dish-photo {
  width: 180rpx;
  height: 180rpx;
  border-radius: 22rpx;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dish-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.dish-title {
  font-size: 32rpx;
  font-weight: 600;
}

.badge {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.spicy {
  font-size: 26rpx;
}

.dish-summary {
  font-size: 24rpx;
  opacity: 0.8;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.price {
  font-size: 34rpx;
  font-weight: 700;
}

.unit {
  font-size: 24rpx;
  opacity: 0.7;
}

.action {
  display: flex;
  align-items: center;
}

.plus {
  font-size: 40rpx;
  color: #facc15;
  line-height: 1;
}

