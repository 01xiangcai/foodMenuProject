.menu-page {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  height: calc(100vh - 48rpx);
  box-sizing: border-box;
  overflow: hidden;
}

.side-nav {
  width: 190rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  height: 100%;
  overflow-y: scroll;
}

.parent-card {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 16rpx;
  border-radius: 18rpx;
  background: var(--card-bg);
  border: 1rpx solid transparent;
  opacity: 0.5;
  transition: 0.2s;
}

.parent-card.active {
  opacity: 1;
  border-color: var(--card-border);
  box-shadow: var(--glass-shadow);
}

.parent-card .icon {
  font-size: 32rpx;
}

.dish-list {
  flex: 1;
  padding-left: 12rpx;
  padding-right: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  height: 100%;
  overflow-y: scroll;
  min-width: 0;
  box-sizing: border-box;
  overflow-x: hidden;
}

.dish-card {
  display: flex;
  flex-direction: column;
  padding: 20rpx 16rpx;
  border-radius: 24rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  min-width: 0;
  box-sizing: border-box;
  overflow: visible;
  width: 100%;
  position: relative;
  gap: 16rpx;
}

.dish-content {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  width: 100%;
  box-sizing: border-box;
}

.dish-photo {
  width: 180rpx;
  height: 180rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
  flex-shrink: 1;
  box-sizing: border-box;
  overflow: hidden;
}

.dish-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  min-width: 0;
}

.dish-title {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border-color);
  flex-shrink: 0;
  white-space: nowrap;
}

.spicy {
  font-size: 26rpx;
  flex-shrink: 0;
}

.dish-summary {
  font-size: 24rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
  min-width: 0;
  word-break: break-word;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  flex-shrink: 0;
}

.price {
  font-size: 34rpx;
  font-weight: 700;
}

.unit {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.dish-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding-top: 12rpx;
  margin-top: 8rpx;
  border-top: 1rpx solid var(--border-color);
  box-sizing: border-box;
}

.btn-favorite {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
}

.favorite-icon {
  font-size: 36rpx;
  line-height: 1;
  display: block;
}

.action-buttons {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  justify-content: flex-end;
  width: auto;
  box-sizing: border-box;
  margin-left: auto;
}

.quantity-control {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  flex-shrink: 0;
  width: auto;
  overflow: visible;
  position: relative;
}

.btn-minus,
.btn-plus {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  flex-shrink: 0;
  box-sizing: border-box;
}

.btn-plus {
  background: var(--primary-color);
  color: var(--btn-text);
  box-shadow: 0 4rpx 12rpx rgba(20, 184, 255, 0.3);
}

.btn-minus {
  background: var(--input-bg);
  color: var(--text-color);
  border: 1rpx solid var(--border-color);
}

.count {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 700;
  min-width: 40rpx;
  width: auto;
  text-align: center;
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  height: 48rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  background: transparent;
  white-space: nowrap;
}

.list-bottom-placeholder {
  height: 120rpx;
}

/* 购物车条 */
.cart-bar {
  position: fixed;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  z-index: 100;
  background: var(--modal-bg);
  border: 1rpx solid var(--card-border);
}

.cart-icon-wrap {
  position: relative;
  margin-right: 32rpx;
}

.cart-icon {
  font-size: 48rpx;
}

.cart-icon-wrap .badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

.price-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-color);
}

.delivery-tip {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.btn-checkout {
  background: var(--primary-color);
  color: var(--btn-text);
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(20, 184, 255, 0.3);
}
