<view class="menu-page {{theme}}">
  <scroll-view class="side-nav" scroll-y="true">
    <block wx:for="{{categories}}" wx:key="id">
      <view
        class="parent-card"
        data-id="{{item.id}}"
        bindtap="handleParentTap"
        wx:class="{{item.id === activeCategoryId ? 'active' : ''}}"
      >
        <text class="icon">{{item.icon}}</text>
        <text>{{item.name}}</text>
      </view>
    </block>
  </scroll-view>

  <scroll-view class="dish-list" scroll-y="true">
    <block wx:for="{{dishes}}" wx:key="id">
      <navigator
        class="dish-card"
        url="/pages/detail/detail?id={{item.id}}"
        hover-class="none"
        data-id="{{item.id}}"
      >
        <view class="dish-photo-wrapper">
          <image class="dish-photo" mode="aspectFill" src="{{item.image}}" />
          <view class="btn-favorite glass-effect" catchtap="toggleFavorite" data-item="{{item}}">
            <text class="favorite-icon {{item.isFavorite ? 'active' : ''}}">{{item.isFavorite ? '❤️' : '🤍'}}</text>
          </view>
        </view>
        
        <view class="dish-info">
          <view class="dish-header">
            <view class="dish-title-row">
              <text class="dish-title">{{item.name}}</text>
              <text class="badge" wx:if="{{item.badge}}">{{item.badge}}</text>
            </view>
            <text class="dish-summary">{{item.description}}</text>
          </view>
          
          <view class="dish-footer">
            <view class="price-row">
              <text class="currency">¥</text>
              <text class="price">{{item.price}}</text>
              <text class="unit">/份</text>
            </view>
            
            <view class="action-buttons">
              <view class="quantity-control" wx:if="{{cartList[item.id] && cartList[item.id].count > 0}}">
                <view class="btn-minus" catchtap="removeFromCart" data-item="{{item}}">-</view>
                <text class="count">{{cartList[item.id].count}}</text>
              </view>
              <view class="btn-plus" catchtap="addToCart" data-item="{{item}}">＋</view>
            </view>
          </view>
        </view>
      </navigator>
    </block>
    <view class="list-bottom-placeholder"></view>
  </scroll-view>

  <!-- 购物车详情弹窗 -->
  <view class="cart-popup-mask" wx:if="{{showCart && totalCount > 0}}" bindtap="hideCartPopup"></view>
  <view class="cart-popup" wx:if="{{showCart && totalCount > 0}}">
    <view class="cart-header">
      <text class="cart-title">已选商品</text>
      <view class="cart-clear" bindtap="clearCart">
        <text class="icon">🗑️</text>
        <text>清空</text>
      </view>
    </view>
    <scroll-view class="cart-list" scroll-y="true">
      <block wx:for="{{cartList}}" wx:key="id" wx:for-item="item">
        <view class="cart-item">
          <image class="cart-item-image" src="{{item.image}}" mode="aspectFill" />
          <view class="cart-item-info">
            <text class="cart-item-name">{{item.name}}</text>
            <text class="cart-item-price">¥{{item.price}}</text>
          </view>
          <view class="quantity-control">
            <view class="btn-minus" catchtap="removeFromCart" data-item="{{item}}">-</view>
            <text class="count">{{item.count}}</text>
            <view class="btn-plus" catchtap="addToCart" data-item="{{item}}">＋</view>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>

  <!-- 底部购物车条 -->
  <view class="cart-bar glass-card" wx:if="{{totalCount > 0}}" bindtap="toggleCartPopup">
    <view class="cart-icon-wrap">
      <text class="cart-icon">🛒</text>
      <view class="badge">{{totalCount}}</view>
    </view>
    <view class="price-info">
      <text class="total-price">¥{{totalPrice}}</text>
      <text class="delivery-tip">免配送费</text>
    </view>
    <view class="btn-checkout" catchtap="goToCheckout">去结算</view>
  </view>
</view>

