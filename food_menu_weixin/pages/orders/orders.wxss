@import "../../styles/theme.wxss";

.page {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 40rpx;
}

.orders-container {
  height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.5;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-color);
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 订单列表 */
.orders-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 订单卡片 */
.order-card {
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: var(--glass-shadow);
  transition: all 0.3s ease;
  box-sizing: border-box;
  overflow: hidden;
}

.order-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  gap: 16rpx;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
  padding-right: 12rpx;
  overflow: hidden;
}

.order-number {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
  word-break: break-all;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
}

.order-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.order-status {
  font-size: 26rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(20, 184, 255, 0.1);
  border: 1rpx solid currentColor;
  opacity: 0.8;
  flex-shrink: 0;
  white-space: nowrap;
  margin-left: auto;
}

/* 订单商品列表 */
.order-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.order-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-right: 0;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: var(--input-bg);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-spec {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.item-price {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
  flex-shrink: 0;
  margin-left: auto;
  padding-left: 12rpx;
  min-width: 80rpx;
  text-align: right;
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color);
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.order-total {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  flex-shrink: 0;
  flex: 0 0 auto;
  min-width: 160rpx;
  margin-right: 16rpx;
}

.total-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
  white-space: nowrap;
}

.total-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary-color);
  flex-shrink: 0;
  white-space: nowrap;
}

.order-actions {
  display: flex;
  gap: 8rpx;
  flex-shrink: 1;
  justify-content: flex-end;
  align-items: center;
  min-width: 0;
  flex-wrap: nowrap;
  max-width: calc(100% - 200rpx);
}

.action-btn {
  padding: 10rpx 8rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  border: none;
  transition: all 0.3s ease;
  line-height: 1.3;
  white-space: nowrap;
  flex-shrink: 1;
  box-sizing: border-box;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cancel-btn {
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
  padding: 10rpx 8rpx;
  font-size: 22rpx;
  max-width: 70rpx;
}

.cancel-btn:active {
  background: var(--input-bg);
  opacity: 0.8;
}

.detail-btn {
  background: var(--primary-color);
  color: var(--btn-text);
  font-weight: 500;
  padding: 10rpx 8rpx;
  font-size: 22rpx;
  max-width: 70rpx;
}

.detail-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* 订单商品为空 */
.order-items-empty {
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
}
