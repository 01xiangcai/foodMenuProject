.page {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.timeline-card,
.history-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.timeline-row {
  display: flex;
  gap: 16rpx;
  position: relative;
}

.timeline-row::before {
  content: '';
  position: absolute;
  left: 16rpx;
  top: 0;
  bottom: -20rpx;
  border-left: 2rpx dashed rgba(255, 255, 255, 0.2);
}

.timeline-row:last-child::before {
  display: none;
}

.dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  box-shadow: 0 0 24rpx rgba(20, 184, 255, 0.5);
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.time {
  font-size: 26rpx;
  opacity: 0.8;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
}

.status {
  font-size: 24rpx;
  color: #38bdf8;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
}

.number {
  font-size: 24rpx;
  opacity: 0.6;
}

.dish {
  display: block;
  font-size: 28rpx;
  margin-top: 8rpx;
}

.amount-area {
  text-align: right;
}

.amount {
  font-size: 30rpx;
  font-weight: 600;
}

.status-pill {
  display: inline-flex;
  margin-top: 8rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  font-size: 24rpx;
}

