<view class="page {{theme}}">
  <!-- 订单列表 -->
  <scroll-view 
    class="orders-container"
    scroll-y="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
    bindscrolltolower="onReachBottom"
  >
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{orders.length === 0 && !loading}}">
      <view class="empty-icon">📦</view>
      <text class="empty-text">暂无订单</text>
      <text class="empty-desc">快去下单吧~</text>
    </view>

    <!-- 订单列表 -->
    <view class="orders-list" wx:if="{{orders.length > 0}}">
      <view 
        class="order-card" 
        wx:for="{{orders}}" 
        wx:key="id"
        bindtap="viewOrderDetail"
        data-id="{{item.id}}"
      >
        <!-- 订单头部 -->
        <view class="order-header">
          <view class="order-info">
            <text class="order-number">订单号：{{item.orderNumber}}</text>
            <text class="order-time">{{item.createTimeText}}</text>
          </view>
          <view class="order-status" style="color: {{item.statusColor}}">
            {{item.statusText}}
          </view>
        </view>

        <!-- 订单商品列表 -->
        <view class="order-items" wx:if="{{item.orderItems && item.orderItems.length > 0}}">
          <view 
            class="order-item" 
            wx:for="{{item.orderItems}}" 
            wx:key="id"
            wx:for-item="orderItem"
          >
            <image 
              class="item-image" 
              src="{{orderItem.dishImage}}" 
              mode="aspectFill"
            ></image>
            <view class="item-info">
              <text class="item-name">{{orderItem.dishName}}</text>
              <text class="item-spec">x{{orderItem.quantity}}</text>
            </view>
            <text class="item-price">¥{{orderItem.subtotal}}</text>
          </view>
        </view>
        <view class="order-items-empty" wx:else>
          <text class="empty-text">暂无商品信息</text>
        </view>

        <!-- 订单底部 -->
        <view class="order-footer">
          <view class="order-total">
            <text class="total-label">合计：</text>
            <text class="total-amount">¥{{item.totalAmount}}</text>
          </view>
          <view class="order-actions">
            <button 
              class="action-btn cancel-btn" 
              wx:if="{{item.canCancel}}"
              catchtap="cancelOrder"
              data-id="{{item.id}}"
              data-number="{{item.orderNumber}}"
            >
              取消
            </button>
            <button 
              class="action-btn detail-btn" 
              catchtap="viewOrderDetail"
              data-id="{{item.id}}"
            >
              详情
            </button>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{orders.length > 0}}">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:elif="{{!hasMore}}">没有更多了</text>
      <text wx:else>上拉加载更多</text>
    </view>
  </scroll-view>
</view>
