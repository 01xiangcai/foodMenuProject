.page {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.hero {
  position: relative;
  overflow: hidden;
}

.hero-text {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.eyebrow {
  letter-spacing: 6rpx;
  font-size: 24rpx;
  opacity: 0.7;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
}

.hero-sub {
  opacity: 0.8;
}

.hero-ring {
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 3rpx dashed var(--hero-ring);
  box-shadow: 0 0 40rpx var(--hero-shadow);
}

.section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mini-tip {
  font-size: 22rpx;
  opacity: 0.6;
}

.banner-swiper {
  width: 100%;
  height: 360rpx !important;
  border-radius: 24rpx;
  overflow: hidden;
  background: var(--card-bg);
  margin-top: 20rpx;
}

swiper-item {
  width: 100% !important;
  height: 100% !important;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-card {
  position: relative;
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: var(--modal-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-image {
  width: 100% !important;
  height: 360rpx !important;
  display: block !important;
  object-fit: cover;
  background: var(--card-bg);
  border-radius: 24rpx;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.banner-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--tag-bg);
}

.placeholder-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
  padding: 32rpx 24rpx 24rpx;
  z-index: 2;
}

.banner-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.banner-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.5);
}

.banner-link {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.quick-card {
  border-radius: 20rpx;
  padding: 20rpx;
  background: var(--tag-bg);
  min-height: 120rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  transition: transform 0.2s;
}

.quick-card:active {
  transform: scale(0.96);
}

.label {
  font-weight: 600;
}

.desc {
  font-size: 24rpx;
  opacity: 0.8;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dish-card {
  border-radius: 20rpx;
  padding: 20rpx;
  background: var(--card-bg);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dish-title {
  font-size: 30rpx;
  font-weight: 600;
}

.dish-tag {
  display: inline-flex;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  background: var(--tag-bg);
  font-size: 22rpx;
  margin-top: 8rpx;
}

.dish-energy {
  font-size: 24rpx;
  color: var(--text-secondary);
}

