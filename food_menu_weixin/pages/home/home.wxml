<view class="page">
  <view class="hero glass-card">
    <view class="hero-text">
      <text class="eyebrow">家宴能量中心</text>
      <text class="hero-title">现在是 {{now}}</text>
      <text class="hero-sub">今晚吃什么？一起投票决定</text>
    </view>
    <view class="hero-ring pulse"></view>
  </view>

  <view class="section glass-card">
    <view class="section-header">
      <text class="section-title">美食轮播</text>
      <text class="mini-tip">左右滑动查看更多</text>
    </view>
    <swiper 
      class="banner-swiper" 
      indicator-dots="{{banners.length > 1}}" 
      indicator-color="rgba(255,255,255,0.3)" 
      indicator-active-color="#14b8ff" 
      autoplay="{{banners.length > 1}}" 
      circular="{{banners.length > 1}}" 
      interval="3000" 
      duration="500">
      <block wx:for="{{banners}}" wx:key="id">
        <swiper-item>
          <view class="banner-card">
            <image 
              class="banner-image" 
              mode="aspectFill" 
              src="{{item.image}}" 
              lazy-load="{{false}}"
              binderror="onBannerImageError"
              bindload="onBannerImageLoad"
              data-index="{{index}}"
            />
            <view class="banner-overlay" wx:if="{{item.title || item.description}}">
              <view class="banner-content">
                <text class="banner-title" wx:if="{{item.title}}">{{item.title}}</text>
                <text class="banner-desc" wx:if="{{item.description}}">{{item.description}}</text>
              </view>
            </view>
            <navigator 
              url="{{item.linkUrl || '/pages/menu/menu'}}" 
              hover-class="none"
              class="banner-link"
            >
            </navigator>
          </view>
        </swiper-item>
      </block>
    </swiper>
  </view>

  <view class="section glass-card">
    <view class="section-header">
      <text class="section-title">快捷操作</text>
      <text class="mini-tip">一键触达家人</text>
    </view>
    <view class="quick-grid">
      <block wx:for="{{quickActions}}" wx:key="label">
        <navigator url="{{item.link}}" hover-class="none">
          <view class="quick-card">
            <text class="label">{{item.label}}</text>
            <text class="desc">{{item.desc}}</text>
          </view>
        </navigator>
      </block>
    </view>
  </view>

  <view class="section glass-card">
    <view class="section-header">
      <text class="section-title">明星菜</text>
      <text class="mini-tip">AI 推荐 · 适配家庭口味</text>
    </view>
    <view class="dish-list">
      <block wx:for="{{featuredDishes}}" wx:key="title">
        <view class="dish-card">
          <view>
            <text class="dish-title">{{item.title}}</text>
            <text class="dish-tag">{{item.tag}}</text>
          </view>
          <text class="dish-energy">{{item.energy}}</text>
        </view>
      </block>
    </view>
  </view>
</view>

