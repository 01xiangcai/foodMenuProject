@import "../../styles/theme.wxss";

.favorites-page {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 24rpx;
  box-sizing: border-box;
}

/* 页面头部 */
.page-header {
  margin-bottom: 24rpx;
}

.header-content {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-color);
}

.header-count {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  min-height: 60vh;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.6;
  margin-bottom: 40rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.8;
  }
}

.empty-text {
  font-size: 36rpx;
  color: var(--text-color);
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
  text-align: center;
}

.empty-btn {
  padding: 20rpx 48rpx;
  background: var(--primary-color);
  color: var(--btn-text);
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(20, 184, 255, 0.3);
  transition: all 0.3s ease;
}

.empty-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(20, 184, 255, 0.4);
}

.btn-text {
  color: var(--btn-text);
}

/* 收藏列表 */
.favorites-list {
  height: calc(100vh - 48rpx);
  padding-bottom: 20rpx;
}

/* 收藏卡片 */
.favorite-card {
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: var(--glass-shadow);
  transition: all 0.3s ease;
  position: relative;
}

.favorite-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
  opacity: 0;
  transition: opacity 0.3s ease;
}

.favorite-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(20, 184, 255, 0.25);
}

.favorite-card:active::before {
  opacity: 1;
}

.dish-content {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  align-items: flex-start;
}

.dish-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background: var(--input-bg);
  transition: transform 0.3s ease;
}

.favorite-card:active .dish-image {
  transform: scale(1.05);
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.dish-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: var(--primary-color);
  color: var(--btn-text);
  flex-shrink: 0;
  white-space: nowrap;
}

.dish-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-word;
}

.dish-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.price-info {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.price {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.unit {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 操作按钮 */
.favorite-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid var(--border-color);
  background: var(--input-bg);
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  transition: all 0.2s;
}

.remove-btn {
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
}

.remove-btn:active {
  background: rgba(255, 77, 77, 0.1);
  color: #ff4d4d;
  border-color: rgba(255, 77, 77, 0.3);
  transform: scale(0.95);
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 26rpx;
}

/* 加载中 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(5, 10, 31, 0.8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-color);
}

.list-bottom-placeholder {
  height: 40rpx;
}

