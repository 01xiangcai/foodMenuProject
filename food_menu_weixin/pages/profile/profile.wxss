.profile-page {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  min-height: 100vh;
  padding-bottom: 120rpx; /* 为底部导航栏留出空间 */
}

.user-card {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 28rpx;
  width: 100%;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  min-width: 120rpx;
  flex-shrink: 0;
  border-radius: 50%;
  border: 3rpx solid rgba(20, 184, 255, 0.3);
  box-shadow: 0 0 20rpx rgba(20, 184, 255, 0.4);
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
  justify-content: center;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  color: #f8fafc;
}

.user-phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.edit-btn {
  padding: 16rpx 28rpx;
  background: rgba(20, 184, 255, 0.15);
  border: 1rpx solid rgba(20, 184, 255, 0.3);
  border-radius: 20rpx;
  color: #14b8ff;
  font-size: 28rpx;
  white-space: nowrap;
  flex-shrink: 0;
  line-height: 1;
  height: fit-content;
}

.login-prompt {
  display: flex;
  align-items: center;
  gap: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  min-width: 120rpx;
  flex-shrink: 0;
  border-radius: 50%;
  border: 3rpx dashed rgba(255, 255, 255, 0.2);
  background: linear-gradient(135deg, rgba(20, 184, 255, 0.2), rgba(168, 85, 247, 0.2));
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 60rpx;
  opacity: 0.6;
}

.login-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
  justify-content: center;
  overflow: hidden;
}

.login-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #f8fafc;
  line-height: 1.5;
  display: block;
}

.login-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.5;
  display: block;
}

.login-btn {
  padding: 20rpx 36rpx;
  margin: 0;
  background: linear-gradient(120deg, #14b8ff, #a855f7);
  border: none;
  border-radius: 20rpx;
  color: #021221;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(20, 184, 255, 0.35);
  white-space: nowrap;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: opacity 0.2s;
}

.login-btn:active {
  opacity: 0.8;
}

.login-btn text {
  color: #021221;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
}

.menu-section {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  transition: background 0.3s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.menu-icon {
  font-size: 40rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #f8fafc;
}

.logout-text {
  color: rgba(255, 100, 100, 0.9);
}

.menu-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 登录弹窗 */
.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(10rpx);
}

.modal-content {
  width: 600rpx;
  background: linear-gradient(135deg, rgba(10, 17, 32, 0.95), rgba(5, 10, 31, 0.95));
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 0;
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(20rpx);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #f8fafc;
}

.modal-close {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.5);
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s;
}

.modal-close:active {
  background: rgba(255, 255, 255, 0.1);
}

.modal-body {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.input-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.input-field {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  color: #f8fafc;
  font-size: 30rpx;
}

.input-field::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.submit-btn {
  margin-top: 16rpx;
  padding: 24rpx;
  background: linear-gradient(120deg, #14b8ff, #a855f7);
  border: none;
  border-radius: 16rpx;
  color: #021221;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(20, 184, 255, 0.35);
}

.submit-btn:active {
  opacity: 0.9;
}

/* 头像上传 */
.avatar-upload {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx dashed rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.avatar-upload:active {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(20, 184, 255, 0.4);
}

.avatar-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-upload .avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.upload-icon {
  font-size: 64rpx;
  opacity: 0.5;
}

.upload-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

