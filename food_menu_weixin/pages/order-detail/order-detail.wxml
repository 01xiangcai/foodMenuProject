<view class="page {{theme}}">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 订单详情 -->
  <scroll-view class="detail-container" scroll-y="{{true}}" wx:else>
    <!-- 订单状态卡片 -->
    <view class="status-card" wx:if="{{order}}">
      <view class="status-icon" style="color: {{order.statusColor}}">
        {{order.statusIcon}}
      </view>
      <text class="status-text" style="color: {{order.statusColor}}">
        {{order.statusText}}
      </text>
      <text class="order-number">订单号：{{order.orderNumber}}</text>
      <text class="order-time">{{order.createTimeText}}</text>
    </view>

    <!-- 订单商品列表 -->
    <view class="section-card" wx:if="{{order}}">
      <view class="section-title">订单商品</view>
      <view class="items-list">
        <view 
          class="item-row" 
          wx:for="{{order.orderItems}}" 
          wx:key="id"
        >
          <image 
            class="item-image" 
            src="{{item.dishImage}}" 
            mode="aspectFill"
          ></image>
          <view class="item-info">
            <text class="item-name">{{item.dishName}}</text>
            <text class="item-spec">¥{{item.price}} x {{item.quantity}}</text>
          </view>
          <text class="item-subtotal">¥{{item.subtotal}}</text>
        </view>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="section-card" wx:if="{{order}}">
      <view class="section-title">订单信息</view>
      <view class="info-list">
        <view class="info-row">
          <text class="info-label">订单金额</text>
          <text class="info-value price">¥{{order.totalAmount}}</text>
        </view>
        <view class="info-row" wx:if="{{order.remark}}">
          <text class="info-label">备注</text>
          <text class="info-value">{{order.remark}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar" wx:if="{{order && order.canCancel}}">
      <button class="cancel-btn" bindtap="cancelOrder">
        取消订单
      </button>
    </view>
  </scroll-view>
</view>

