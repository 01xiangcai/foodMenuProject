@import "../../styles/theme.wxss";

.page {
  min-height: 100vh;
  background: var(--bg-color);
}

/* 加载中 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 详情容器 */
.detail-container {
  height: 100vh;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 状态卡片 */
.status-card {
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: var(--glass-shadow);
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 10rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
}

.order-number {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

.order-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 区块卡片 */
.section-card {
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--glass-shadow);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

/* 商品列表 */
.items-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.item-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.item-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: var(--input-bg);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.item-name {
  font-size: 30rpx;
  color: var(--text-color);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-spec {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.item-subtotal {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary-color);
  flex-shrink: 0;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 500;
  text-align: right;
  max-width: 60%;
  word-break: break-all;
}

.info-value.price {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary-color);
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: var(--card-bg);
  border-top: 1rpx solid var(--border-color);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.cancel-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
}

.cancel-btn:active {
  background: var(--input-bg);
  opacity: 0.8;
}

