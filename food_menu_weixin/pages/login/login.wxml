<view class="container {{theme}}">
  <view class="login-header">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="title">欢迎回来</text>
  </view>

  <view class="login-form">
    <view class="input-group">
      <text class="label">用户名</text>
      <input class="input" type="text" placeholder="请输入用户名" model:value="{{username}}" />
    </view>
    <view class="input-group">
      <text class="label">密码</text>
      <input class="input" type="password" placeholder="请输入密码" model:value="{{password}}" />
    </view>
    
    <block wx:if="{{isRegister}}">
      <view class="input-group">
        <text class="label">确认密码</text>
        <input class="input" type="password" placeholder="请再次输入密码" model:value="{{confirmPassword}}" />
      </view>
      <view class="input-group">
        <text class="label">昵称 (选填)</text>
        <input class="input" type="text" placeholder="请输入昵称" model:value="{{nickname}}" />
      </view>
    </block>

    <button class="btn-login" bindtap="{{isRegister ? 'handleRegister' : 'handleLogin'}}">
      {{isRegister ? '注册' : '登录'}}
    </button>
    
    <view class="toggle-area" bindtap="toggleMode">
      <text class="toggle-text">{{isRegister ? '已有账号？去登录' : '没有账号？去注册'}}</text>
    </view>
  </view>
</view>
