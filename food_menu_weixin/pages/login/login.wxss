.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  min-height: 100vh;
  background: var(--bg-color);
  transition: background 0.3s;
}

.login-header {
  margin-top: 100rpx;
  margin-bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
  border-radius: 50%;
  border-radius: 50%;
  background-color: #fff;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  font-weight: bold;
  color: var(--text-color);
}

.login-form {
  width: 100%;
  width: 100%;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 40rpx;
  box-sizing: border-box;
  box-shadow: var(--glass-shadow);
  border: 1rpx solid var(--card-border);
}

.input-group {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  width: 100%;
  height: 88rpx;
  background: var(--input-bg);
  border: 1rpx solid var(--input-border);
  border-radius: 10rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: var(--text-color);
}

.btn-login {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  line-height: 88rpx;
  background: var(--primary-color);
  color: var(--btn-text);
  font-size: 32rpx;
  border-radius: 44rpx;
  margin-top: 60rpx;
  font-weight: bold;
}

.btn-login:active {
  opacity: 0.9;
}

.toggle-area {
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.toggle-text {
  font-size: 28rpx;
  color: var(--primary-color);
  padding: 10rpx 20rpx;
}
