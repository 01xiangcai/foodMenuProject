.page {
  padding: 24rpx;
  padding-bottom: 140rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--bg-color);
}

.section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
}

.delivery-options {
  display: flex;
  gap: 24rpx;
}

.option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: var(--input-bg);
  border: 1rpx solid var(--border-color);
  color: var(--text-secondary);
  transition: all 0.3s;
}

.option.active {
  background: rgba(20, 184, 255, 0.1);
  border-color: var(--primary-color);
  color: var(--primary-color);
}

.address-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.address {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
}

.contact {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.item-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background: var(--input-bg);
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.item-name {
  font-size: 28rpx;
  color: var(--text-color);
}

.item-price {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
}

.item-count {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color);
  font-size: 30rpx;
  color: var(--text-color);
}

.total-price {
  font-weight: 600;
  font-size: 34rpx;
}

.remark-input {
  width: 100%;
  height: 160rpx;
  background: var(--input-bg);
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--text-color);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--modal-bg);
  border-top: 1rpx solid var(--card-border);
  z-index: 100;
}

.price-info {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  color: var(--text-color);
  font-size: 28rpx;
}

.final-price {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.btn-submit {
  margin: 0;
  background: linear-gradient(120deg, #14b8ff, #a855f7);
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(20, 184, 255, 0.3);
}
