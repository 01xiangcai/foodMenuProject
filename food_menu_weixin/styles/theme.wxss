/* Tech Theme (Default) */
.tech {
  --bg-color: radial-gradient(circle at top, #101737 0%, #050a1f 60%, #030614 100%);
  --text-color: #f8fafc;
  --text-secondary: rgba(255, 255, 255, 0.6);
  --card-bg: rgba(255, 255, 255, 0.04);
  --card-border: rgba(255, 255, 255, 0.08);
  --primary-color: #14b8ff;
  --accent-color: #a855f7;
  --glass-shadow: 0 30rpx 60rpx rgba(10, 20, 50, 0.35);
  --input-bg: rgba(255, 255, 255, 0.05);
  --input-border: rgba(255, 255, 255, 0.1);
  --modal-bg: linear-gradient(135deg, rgba(10, 17, 32, 0.95), rgba(5, 10, 31, 0.95));
  --btn-text: #021221;
  --menu-hover: rgba(255, 255, 255, 0.05);
  --border-color: rgba(255, 255, 255, 0.05);
  --hero-ring: rgba(255, 255, 255, 0.2);
  --hero-shadow: rgba(20, 184, 255, 0.4);
  --tag-bg: rgba(20, 184, 255, 0.2);
}

/* Family Theme */
.family {
  --bg-color: #FFF8F0;
  --text-color: #2d3436;
  --text-secondary: #636e72;
  --card-bg: #ffffff;
  --card-border: rgba(0, 0, 0, 0.05);
  --primary-color: #FF9F43;
  --accent-color: #FFC312;
  --glass-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
  --input-bg: #f1f2f6;
  --input-border: #dfe6e9;
  --modal-bg: #ffffff;
  --btn-text: #ffffff;
  --menu-hover: rgba(0, 0, 0, 0.02);
  --border-color: rgba(0, 0, 0, 0.05);
  --hero-ring: rgba(255, 159, 67, 0.3);
  --hero-shadow: rgba(255, 159, 67, 0.2);
  --tag-bg: rgba(255, 159, 67, 0.15);
}
